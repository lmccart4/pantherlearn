rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms
    match /classrooms/{classroomId} {
      // Anyone authenticated can read (needed for join by code)
      allow read: if request.auth != null;
      // Only teachers can create
      allow create: if request.auth != null;
      // Teacher who owns it can update
      allow update: if request.auth != null;

      // Students subcollection
      match /students/{studentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == studentId;
        allow update: if request.auth != null && request.auth.uid == studentId;
      }
    }

    // Investigations
    match /investigations/{investigationId} {
      // Students can read their own, teachers can read all in their classroom
      allow read: if request.auth != null;
      // Students can create their own investigations
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      // Students can update their own active investigations
      allow update: if request.auth != null && resource.data.studentId == request.auth.uid;
    }
  }
}
