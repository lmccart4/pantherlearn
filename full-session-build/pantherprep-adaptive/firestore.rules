// firestore.rules — Adaptive Engine additions
// Merge these with your existing PantherPrep Firestore rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // EXISTING COLLECTIONS (your current rules stay as-is)
    // ============================================================

    // students/{uid} — existing student profiles
    // sessions/{sessionId} — existing session logs
    // questionStats/{questionId} — existing question stats

    // ============================================================
    // NEW ADAPTIVE ENGINE COLLECTIONS
    // ============================================================

    // Performance Log — granular per-answer tracking
    // Students can only write their own answers, teachers can read all
    match /performanceLog/{uid}/answers/{answerId} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        isTeacher(request.auth.uid)
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false; // Answers are immutable
    }

    // Adaptive Profile — computed mastery state
    // Students can read their own, system can write (via Cloud Functions or client)
    // Teachers can read all profiles
    match /adaptiveProfile/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        isTeacher(request.auth.uid)
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Question Pool — normalized question bank
    // Everyone can read, only teachers can write
    match /questionPool/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isTeacher(request.auth.uid);
    }

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================

    // Check if user is a teacher
    // Adjust this to match your existing auth structure
    function isTeacher(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.role == "teacher";
    }
  }
}
