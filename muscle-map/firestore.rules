rules_version = '2';
// MYO-ID leaderboard. Public read; anyone can submit a validated score; no edits/deletes.
service cloud.firestore {
  match /databases/{database}/documents {
    function validScore() {
      let d = request.resource.data;
      return d.name is string && d.name.size() >= 1 && d.name.size() <= 30
        && d.period is int && d.period >= 1 && d.period <= 9
        && d.score is int && d.score >= 0 && d.score <= 100000
        && d.pct is int && d.pct >= 0 && d.pct <= 100;
    }
    match /scores/{doc} { allow read: if true; allow create: if validScore(); allow update, delete: if false; }

    // AI Literacy final-review app (ai-lit-review). Students own their answer logs
    // and profile (doc id = their email); teachers can read all for the dashboard.
    function aiReviewTeacher() {
      return request.auth != null &&
        request.auth.token.email in ["lucamccarthy@paps.net", "thombabyak@paps.net"];
    }
    match /aiReviewAnswers/{id} {
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.email;
      allow read: if request.auth != null &&
        (request.auth.token.email == resource.data.email || aiReviewTeacher());
      allow update, delete: if false;
    }
    match /aiReviewProfiles/{email} {
      allow read, write: if request.auth != null &&
        (request.auth.token.email == email || aiReviewTeacher());
    }

    // Physics final-review app (physics-review). Same ownership model as ai-review;
    // reuses aiReviewTeacher() (same teachers).
    match /physicsReviewAnswers/{id} {
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.email;
      allow read: if request.auth != null &&
        (request.auth.token.email == resource.data.email || aiReviewTeacher());
      allow update, delete: if false;
    }
    match /physicsReviewProfiles/{email} {
      allow read, write: if request.auth != null &&
        (request.auth.token.email == email || aiReviewTeacher());
    }
  }
}
